{% extends 'base.html.twig' %}

{% block title %}Prendre Rendez-vous via WhatsApp{% endblock %}

{% block body %}
<div class="py-12 px-4 md:px-6">
    <div class="max-w-2xl mx-auto bg-slate-900/60 backdrop-blur-xl border border-white/10 shadow-2xl rounded-2xl p-8 md:p-12">
        
        <div class="text-center mb-8">
            <h1 class="text-3xl font-extrabold text-white">Prendre Rendez-vous 💬</h1>
            <p class="text-slate-400 mt-2">Remplissez ce formulaire pour m'envoyer votre demande directement sur mon WhatsApp.</p>
        </div>

        {# Utilisation d'une balise form pour gérer la soumission et la touche "Entrée" #}
        <form onsubmit="event.preventDefault(); envoyerWhatsApp();" class="space-y-6">
            <div>
                <label for="name" class="block text-sm font-semibold text-slate-300">Votre Nom complet</label>
                <input type="text" id="name" required class="mt-1 block w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
            </div>

            <div>
                <label for="email" class="block text-sm font-semibold text-slate-300">Votre Adresse E-mail</label>
                <input type="email" id="email" required class="mt-1 block w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
            </div>

            <div>
                <label for="subject" class="block text-sm font-semibold text-slate-300">Objet du projet</label>
                <input type="text" id="subject" required class="mt-1 block w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
            </div>

            <div>
                <label for="message" class="block text-sm font-semibold text-slate-300">Détails de votre demande</label>
                <textarea id="message" rows="5" required class="mt-1 block w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 transition"></textarea>
            </div>

            {# Bouton avec style forcé pour garantir la couleur verte WhatsApp #}
            <button type="submit" 
                    style="background-color: #25D366 !important; color: white !important;" 
                    class="w-full font-bold py-4 px-6 rounded-lg shadow-[0_0_15px_rgba(37,211,102,0.3)] transition duration-300 transform hover:scale-[1.02] hover:bg-[#1da851]">
                💬 Discuter sur WhatsApp
            </button>
        </form>
    </div>
</div>

<script>
function envoyerWhatsApp() {
    // Numéro au format international sans le '+'
    var monNumero = "22952838253"; 
    
    var name = document.getElementById('name').value;
    var email = document.getElementById('email').value;
    var subject = document.getElementById('subject').value;
    var message = document.getElementById('message').value;
    
    var texteMessage = "Bonjour Farouck ! 👋\n\n" +
                       "*Nouveau projet client :* " + subject + "\n" +
                       "*Nom :* " + name + "\n" +
                       "*E-mail :* " + email + "\n\n" +
                       "*Détails :*\n" + message;
    
    // Construction correcte de l'URL pour l'API WhatsApp
    var url = "https://wa.me/" + monNumero + "?text=" + encodeURIComponent(texteMessage);
    
    // Ouverture dans un nouvel onglet
    window.open(url, '_blank');
}
</script>
{% endblock %}