{% extends 'base.html.twig' %}

{% block title %}Mon CV - Farouck{% endblock %}

{% block body %}
<div class="py-12 px-4 md:px-6">
    <div class="max-w-5xl mx-auto bg-slate-900/40 backdrop-blur-xl border border-white/10 shadow-2xl rounded-2xl overflow-hidden flex flex-col md:flex-row">
        
        {# Section de Gauche : Ta nouvelle Photo et Profil #}
        <div class="w-full md:w-2/5 bg-white text-slate-900 flex flex-col items-center">
            {# Bloc photo complet adapté à ton portrait assis #}
            <div class="w-full aspect-[4/5] bg-slate-100 overflow-hidden">
                <img src="{{ asset('images/moi.jpg') }}" alt="Farouck" class="w-full h-full object-contain">
            </div>
            {# Infos sous la photo #}
            <div class="p-8 text-center w-full bg-slate-950 text-white">
                <h1 class="text-3xl font-extrabold tracking-wide uppercase">Farouck</h1>
                <p class="text-indigo-400 text-lg font-medium mt-2">Développeur Backend & Frontend</p>
                <div class="w-16 h-1 bg-indigo-500 mx-auto mt-4 rounded-full"></div>
            </div>
        </div>

        {# Section de Droite : Parcours détaillé en texte blanc/lumineux #}
        <div class="w-full md:w-3/5 p-8 md:p-12 space-y-10 text-slate-200">
            {# À propos de moi #}
            <div>
                <h2 class="text-2xl font-bold text-white border-b-2 border-white/10 pb-2">À propos de moi</h2>
                <div class="mt-4 space-y-4 leading-relaxed text-base text-slate-300">
                    <p>
                        Bienvenue sur mi-portfolio ! En tant que **développeur Backend et Frontend**, je conçois des applications web robustes et sécurisées tout en créant des interfaces utilisateur fluides, modernes et dynamiques.
                    </p>
                    <p>
                        Passionné par le code et la résolution de problèmes techniques, j'accorde une importance particulière à la qualité du code et à l'expérience utilisateur.
                    </p>
                </div>
            </div>

            {# Mes Formations #}
            <div>
                <h2 class="text-2xl font-bold text-white border-b-2 border-white/10 pb-2">Mes Formations</h2>
                <ul class="mt-4 space-y-4">
                    <li class="flex items-start">
                        <span class="text-indigo-400 mr-3 text-xl">✔</span>
                        <div>
                            <strong class="text-white text-lg">Formation Développeur Web Complet</strong>
                            <p class="text-sm text-indigo-400 font-medium">Autodidacte & Formations Spécialisées</p>
                            <p class="text-sm text-slate-400 mt-1">Maîtrise de l'architecture MVC, de la gestion des bases de données (SQL), et de l'intégration moderne (Tailwind CSS, JavaScript).</p>
                        </div>
                    </li>
                </ul>
            </div>

            {# Compétences #}
            <div>
                <h2 class="text-2xl font-bold text-white border-b-2 border-white/10 pb-2">Compétences Techniques</h2>
                <div class="mt-4 flex flex-wrap gap-2">
                    <span class="bg-white/5 text-indigo-300 px-3 py-1 rounded-full text-sm font-semibold border border-white/10">Symfony</span>
                    <span class="bg-white/5 text-indigo-300 px-3 py-1 rounded-full text-sm font-semibold border border-white/10">PHP</span>
                    <span class="bg-white/5 text-indigo-300 px-3 py-1 rounded-full text-sm font-semibold border border-white/10">Tailwind CSS</span>
                    <span class="bg-white/5 text-indigo-300 px-3 py-1 rounded-full text-sm font-semibold border border-white/10">JavaScript</span>
                    <span class="bg-white/5 text-indigo-300 px-3 py-1 rounded-full text-sm font-semibold border border-white/10">MySQL</span>
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}
